---
interface Item {
  title: string;
  description?: string;
  meta?: string;
  href?: string;
}

interface Group {
  id?: string;
  title?: string;
  items: Item[];
}

interface Props {
  groups?: Group[];
  items?: Item[];
  emptyMessage?: string;
  headingLevel?: 2 | 3;
}

const { items = [], groups: suppliedGroups, emptyMessage = '暂无已公开条目。', headingLevel = 2 } = Astro.props;
const Heading = headingLevel === 3 ? 'h3' : 'h2';
const groups: Group[] = suppliedGroups?.filter((group) => group.items.length > 0) ?? (items.length ? [{ items }] : []);
const isExternal = (href?: string) => Boolean(href && /^https?:\/\//.test(href));
---

{groups.length ? (
  <div class="text-directory">
    {groups.map((group) => (
      <section class="text-list-section" id={group.id}>
        {group.title && <Heading class="text-list-heading">{group.title}</Heading>}
        <ul class="text-list">
          {group.items.map((item) => (
            <li>
              {item.href ? (
                <a class="text-list-title" href={item.href} target={isExternal(item.href) ? '_blank' : undefined} rel={isExternal(item.href) ? 'noopener noreferrer' : undefined}>{item.title}</a>
              ) : (
                <span class="text-list-title">{item.title}</span>
              )}
              {item.description && <span class="text-list-description">：{item.description}</span>}
              {item.meta && <span class="text-list-meta">（{item.meta}）</span>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
) : <p class="empty-state">{emptyMessage}</p>}
