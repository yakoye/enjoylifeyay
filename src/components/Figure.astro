---
interface Props { src: string; alt: string; caption?: string; credit?: string; width?: number; }
const { src, alt, caption = '', credit = '', width } = Astro.props;
---
<figure>
  <img src={src} alt={alt} width={width} loading="lazy" decoding="async" />
  {(caption || credit) && <figcaption>{caption}{caption && credit && ' · '}{credit}</figcaption>}
</figure>
