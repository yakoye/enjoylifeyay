---
import { site } from '../config/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="content-shell footer-inner">
    <span>© {year} {site.name}</span>
    <nav aria-label="辅助导航">
      {site.githubUrl && <a href={site.githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>}
      <a href="/rss.xml">RSS</a>
      <a href="/archive/">归档</a>
      <a href="/now/">正在做</a>
      <a href="/about/">关于</a>
    </nav>
  </div>
</footer>
