---
import type { CollectionEntry } from 'astro:content';
import { categoryLabels, formatLabels } from '../config/site';

interface Props { entries: CollectionEntry<'writing'>[]; }
const { entries } = Astro.props;
const dateFormat = new Intl.DateTimeFormat('zh-CN', { dateStyle: 'medium' });
---

{entries.length ? (
  <ol class="writing-list">
    {entries.map((entry) => (
      <li class="writing-item">
        <time datetime={entry.data.date.toISOString()}>{dateFormat.format(entry.data.date)}</time>
        <div>
          <a class="writing-title" href={`/writing/${entry.id}/`}>{entry.data.title}</a>
          <div class="writing-meta">
            {categoryLabels[entry.data.domain]} · {formatLabels[entry.data.format]}
            {entry.data.tags.length > 0 && ` · ${entry.data.tags.slice(0, 3).join(' / ')}`}
            {entry.data.source !== 'native' && ` · 原载于 ${entry.data.source}`}
          </div>
        </div>
      </li>
    ))}
  </ol>
) : <p class="empty-state">内容正在整理中。未确认的旧文章不会提前公开。</p>}
