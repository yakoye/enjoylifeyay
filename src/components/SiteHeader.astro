---
import ThemeToggle from './ThemeToggle.astro';
import { site } from '../config/site';

const pathname = Astro.url.pathname;
const isCurrent = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="nav-shell">
    <a class="site-brand" href="/" aria-label="Enjoy Life 主页">
      <img class="site-brand-mark" src="/favicon-32.png?v=20260701" alt="" width="22" height="22" />
      <span class="site-brand-name">{site.name}</span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      {site.navigation.map(({ href, label }) => (
        <a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a>
      ))}
    </nav>
    <div class="nav-actions">
      <a class="icon-button" href="/search/" aria-label="搜索" title="搜索">
        <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
