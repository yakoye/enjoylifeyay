---
import ThemeToggle from './ThemeToggle.astro';
import { site } from '../config/site';
---

<header class="site-header">
  <div class="nav-shell">
    <nav class="site-nav" aria-label="主导航">
      {site.navigation.map(({ href, label }) => <a href={href}>{label}</a>)}
    </nav>
    <div class="nav-actions">
      <a class="icon-button" href="/search/" aria-label="搜索" title="搜索">
        <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
