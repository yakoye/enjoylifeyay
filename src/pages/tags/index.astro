---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSectionInfo } from '../../config/content-model';
import { getPublicTags, tagHref } from '../../lib/tags';

const page = await getEntry('sitePages', 'tags');
if (!page) throw new Error('Missing Markdown page content: tags');
const writing = await getCollection('writing', ({ data }) => !data.draft);
const tags = getPublicTags(writing);
const groupOrder = ['technology', 'tools', 'reading', 'nature', 'life'] as const;
const groupLabels = { technology: '技术', tools: '工具', reading: '阅读', nature: '自然', life: '生活' } as const;
const groups = groupOrder.map((parent) => {
  const relevant = tags.filter(({ tag }) => {
    const counts = new Map<string, number>();
    for (const entry of writing) {
      if (!entry.data.tags.includes(tag)) continue;
      const key = getSectionInfo(entry.data.section).parent;
      counts.set(key, (counts.get(key) ?? 0) + 1);
    }
    const mostCommon = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'zh-CN'))[0]?.[0];
    return mostCommon === parent;
  });
  return { parent, title: groupLabels[parent], tags: relevant };
}).filter((group) => group.tags.length > 0);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  {groups.length ? (
    <div class="text-directory tag-directory">
      {groups.map((group) => (
        <section class="text-list-section">
          <h2 class="text-list-heading">{group.title}</h2>
          <ul class="text-list">
            {group.tags.map(({ tag, count }) => <li><a class="text-list-title" href={tagHref(tag)}>{tag}</a><span class="text-list-meta">（{count}）</span></li>)}
          </ul>
        </section>
      ))}
    </div>
  ) : <p class="empty-state">暂无可浏览的主题。</p>}
</BaseLayout>
