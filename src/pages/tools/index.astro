---
import { getCollection } from 'astro:content';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const categoryOrder = [
  ['browser-extension', 'Chrome 扩展与网页工具', 'extensions'],
  ['pcie-hardware', 'PCIe / 硬件工具', 'pcie'],
  ['writing-media', '文字、图片与记录工具', 'writing-media'],
  ['websites-life', '个人网站与生活工具', 'websites'],
  ['knowledge-library', '资料库与阅读', 'library'],
  ['personal-system', '个人系统与长期项目', 'projects'],
] as const;

const tools = await getCollection('tools', ({ data }) => !data.draft);
const allFavorites = await getCollection('favorites');
type PublishedFavorite = (typeof allFavorites)[number] & { data: Extract<(typeof allFavorites)[number]['data'], { draft: false }> };
const favorites = allFavorites.filter((entry): entry is PublishedFavorite => entry.data.draft === false);

const groups = [
  ...categoryOrder.map(([category, title, id]) => ({
    id,
    title,
    items: tools
      .filter((entry) => entry.data.category === category)
      .map(({ data }) => ({
        title: data.name,
        description: data.description,
        href: data.url || data.githubUrl || undefined,
      })),
  })),
  {
    id: 'references',
    title: '长期收藏与参考',
    items: favorites.map(({ data }) => ({
      title: data.name,
      description: data.note,
      href: data.url,
    })),
  },
];
---

<BaseLayout title="工具" description="公开工具、个人网站、资料库与长期参考的统一入口。">
  <h1>工具</h1>
  <p class="page-intro">公开工具、个人网站、资料库与长期参考的统一入口。</p>
  <DirectoryList groups={groups} emptyMessage="暂无已确认可以公开的工具或参考。" />
</BaseLayout>
