---
import { getCollection } from 'astro:content';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const categoryOrder = [
  ['browser-extension', '浏览器扩展'],
  ['pcie-hardware', 'PCIe / 硬件工具'],
  ['developer-productivity', '开发效率工具'],
  ['writing-media', '文字、图片与记录工具'],
  ['life', '生活工具'],
] as const;

const entries = await getCollection('tools', ({ data }) => !data.draft);
const groups = categoryOrder.map(([category, title]) => ({
  title,
  items: entries
    .filter((entry) => entry.data.category === category)
    .map(({ data }) => ({
      title: data.name,
      description: data.description,
      href: data.url || data.githubUrl || undefined,
    })),
}));
---

<BaseLayout title="工具" description="在线工具和浏览器扩展目录。">
  <h1>工具</h1>
  <p class="page-intro">在线工具和浏览器扩展。只展示已经确认可以公开的信息。</p>
  <DirectoryList groups={groups} />
</BaseLayout>
