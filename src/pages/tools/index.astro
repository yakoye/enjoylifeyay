---
import { getCollection, getEntry } from 'astro:content';
import SectionMap from '../../components/SectionMap.astro';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVisibleSectionPages } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'tools');
if (!page) throw new Error('Missing Markdown page content: tools');
const tools = (await getCollection('tools', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const mapItems = await getVisibleSectionPages('tools');
const highlights = tools.filter((tool) => tool.data.featured || ['dictfloat', 'regcalc-text-tool', 'pcie-tools-index'].includes(tool.data.id))
  .map(({ data }) => ({ title: data.name, description: data.description, href: data.url || data.githubUrl || undefined }));
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <SectionMap label={page.data.title} sectionHref="/tools/" items={mapItems} />

  <section aria-labelledby="tool-highlights">
    <h2 id="tool-highlights">常用入口</h2>
    <DirectoryList items={highlights} />
  </section>
</BaseLayout>
