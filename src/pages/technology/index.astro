---
import { getCollection, getEntry } from 'astro:content';
import SectionDirectory from '../../components/SectionDirectory.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isInParentSection } from '../../config/content-model';
import { getVisibleSectionPages } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'technology');
if (!page) throw new Error('Missing Markdown page content: technology');
const technicalWriting = (await getCollection('writing', ({ data }) => !data.draft && isInParentSection(data.section, 'technology')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = await getVisibleSectionPages('technology');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <SectionDirectory items={mapItems} />

  <section aria-labelledby="technology-recent-writing">
    <h2 id="technology-recent-writing">最近技术文章</h2>
    <WritingList entries={technicalWriting.slice(0, 8)} />
  </section>
</BaseLayout>
