---
import { getCollection, getEntry } from 'astro:content';
import TopicPreview from '../../components/TopicPreview.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isInParentSection } from '../../config/content-model';
import { getVisibleSectionPageEntries, matchesWritingSectionPage } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'technology');
if (!page) throw new Error('Missing Markdown page content: technology');

const technicalWriting = (await getCollection('writing', ({ data }) => !data.draft && isInParentSection(data.section, 'technology')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sectionPages = await getVisibleSectionPageEntries('technology');
const usedWriting = new Set<string>();
const specificWritingPages = sectionPages.filter((entry) => entry.data.kind === 'writing' && !entry.data.writingSectionPrefix);
const specificWritingCounts = new Map(specificWritingPages.map((entry) => [
  entry.id,
  technicalWriting.filter((writingEntry) => matchesWritingSectionPage(writingEntry, entry)).length,
]));
const topicPreviews = sectionPages.map((sectionPage) => {
  const entries = sectionPage.data.kind === 'writing'
    ? technicalWriting
      .filter((entry) => {
        if (usedWriting.has(entry.id)) return false;
        if (sectionPage.data.routeSlug !== 'articles') return matchesWritingSectionPage(entry, sectionPage);
        const specificOwner = specificWritingPages.find((candidate) => matchesWritingSectionPage(entry, candidate));
        return !specificOwner || (specificWritingCounts.get(specificOwner.id) ?? 0) < 2;
      })
      .slice(0, 3)
    : [];
  entries.forEach((entry) => usedWriting.add(entry.id));
  return { sectionPage, entries };
}).filter(({ sectionPage, entries }) => entries.length > 0 || sectionPage.data.kind === 'markdown');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>

  <div class="topic-preview-list">
    {topicPreviews.map(({ sectionPage, entries }) => (
      <TopicPreview
        title={sectionPage.data.title}
        id={sectionPage.data.routeSlug}
        href={`/${sectionPage.data.section}/${sectionPage.data.routeSlug}/`}
        description={sectionPage.data.description}
        hasContent={entries.length > 0}
      >
        <WritingList entries={entries} emptyMessage={false} />
      </TopicPreview>
    ))}
  </div>
</BaseLayout>
