---
import { getCollection } from 'astro:content';
import DatedTextList from '../../components/DatedTextList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const readingWriting = (await getCollection('writing', ({ data }) => !data.draft && data.domain === 'reading'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((entry) => ({
    title: entry.data.title,
    date: entry.data.date,
    href: `/writing/${entry.id}/`,
  }));
---

<BaseLayout title="阅读" description="读过的书，以及留下来的文字。">
  <h1>阅读</h1>
  <p class="page-intro">读过的书，以及留下来的文字。</p>
  <DatedTextList items={readingWriting} emptyMessage="暂无已核对并公开的内容。" />
</BaseLayout>
