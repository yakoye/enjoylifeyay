---
import { getCollection } from 'astro:content';
import SectionMap from '../../components/SectionMap.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const readingWriting = (await getCollection('writing', ({ data }) => !data.draft && data.domain === 'reading'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = (await getCollection('sectionPages', ({ data }) => !data.draft && data.section === 'reading'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({ title: entry.data.title, href: `/reading/${entry.data.routeSlug}/` }));
---

<BaseLayout title="阅读" description="本站阅读文章、书架、译写计划与按主题整理的站外专题。">
  <h1>阅读</h1>
  <p class="page-intro">本站阅读文章、书架、译写计划与按主题整理的站外专题。</p>
  <SectionMap label="阅读" items={mapItems} />

  <section aria-labelledby="reading-recent-writing">
    <h2 id="reading-recent-writing">最近阅读文章</h2>
    <WritingList entries={readingWriting.slice(0, 8)} />
  </section>
</BaseLayout>
