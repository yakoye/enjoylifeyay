---
import { getCollection, getEntry } from 'astro:content';
import SectionMap from '../../components/SectionMap.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isInParentSection } from '../../config/content-model';
import { getVisibleSectionPages } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'reading');
if (!page) throw new Error('Missing Markdown page content: reading');
const recentWriting = (await getCollection('writing', ({ data }) => !data.draft && isInParentSection(data.section, 'reading')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
const mapItems = await getVisibleSectionPages('reading');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <SectionMap label={page.data.title} sectionHref="/reading/" items={mapItems} />

  <section aria-labelledby="reading-recent-writing">
    <h2 id="reading-recent-writing">最近文章</h2>
    <WritingList entries={recentWriting} emptyMessage={false} />
  </section>
</BaseLayout>
