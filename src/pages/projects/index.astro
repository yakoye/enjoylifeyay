---
import { getCollection } from 'astro:content';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const categoryOrder = [
  ['browser-extension', '浏览器扩展'],
  ['web-tool', '个人网站与工具'],
  ['knowledge-library', '资料库'],
  ['private', '私人项目'],
] as const;

const entries = await getCollection('projects', ({ data }) => !data.draft);
const groups = categoryOrder.map(([category, title]) => ({
  title,
  items: entries
    .filter((entry) => entry.data.category === category)
    .map(({ data }) => ({
      title: data.name,
      description: data.description,
      href: data.url || data.githubUrl || undefined,
    })),
}));
---

<BaseLayout title="项目" description="公开项目的起点、目的和演进目录。">
  <h1>项目</h1>
  <p class="page-intro">项目记录为什么做与如何演进。私人项目只保留公开说明，不接入私有数据。</p>
  <DirectoryList groups={groups} />
</BaseLayout>
