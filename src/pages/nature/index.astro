---
import { getCollection, getEntry } from 'astro:content';
import DatedTextList from '../../components/DatedTextList.astro';
import TopicPreview from '../../components/TopicPreview.astro';
import SectionMap from '../../components/SectionMap.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVisibleSectionPageEntries } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'nature');
if (!page) throw new Error('Missing Markdown page content: nature');
const allEntries = await getCollection('nature');
type PublishedNature = (typeof allEntries)[number] & { data: Extract<(typeof allEntries)[number]['data'], { draft: false }> };
const entries = allEntries.filter((entry): entry is PublishedNature => entry.data.draft === false)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sectionPages = await getVisibleSectionPageEntries('nature');
const usedNature = new Set<string>();
const topicPreviews = sectionPages.map((sectionPage) => {
  const matchedEntries = sectionPage.data.kind === 'nature'
    ? entries
      .filter((entry) => sectionPage.data.natureCategories.includes(entry.data.category) && !usedNature.has(entry.id))
      .slice(0, 3)
    : [];
  matchedEntries.forEach((entry) => usedNature.add(entry.id));
  const items = matchedEntries.map(({ data }) => ({
    title: data.title,
    description: data.description,
    date: data.date,
    meta: [data.location, data.method].filter(Boolean).join(' · '),
    href: data.relatedWriting[0] ? `/writing/${data.relatedWriting[0]}/` : undefined,
  }));
  return { sectionPage, items };
}).filter(({ sectionPage, items }) => items.length > 0 || sectionPage.data.kind === 'markdown');
const categoryItems = sectionPages.map((sectionPage) => ({
  title: sectionPage.data.title,
  href: `/${sectionPage.data.section}/${sectionPage.data.routeSlug}/`,
}));
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>

  <SectionMap label="分类" items={categoryItems} />

  <div class="topic-preview-list">
    {topicPreviews.map(({ sectionPage, items }) => (
      <TopicPreview
        title={sectionPage.data.title}
        id={sectionPage.data.routeSlug}
        href={`/${sectionPage.data.section}/${sectionPage.data.routeSlug}/`}
        description={sectionPage.data.description}
        hasContent={items.length > 0}
      >
        <DatedTextList items={items} emptyMessage={false} />
      </TopicPreview>
    ))}
  </div>
</BaseLayout>
