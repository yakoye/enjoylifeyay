---
import { getCollection } from 'astro:content';
import DatedTextList from '../../components/DatedTextList.astro';
import SectionMap from '../../components/SectionMap.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allEntries = await getCollection('nature');
type PublishedNature = (typeof allEntries)[number] & { data: Extract<(typeof allEntries)[number]['data'], { draft: false }> };
const entries = allEntries.filter((entry): entry is PublishedNature => entry.data.draft === false)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = (await getCollection('sectionPages', ({ data }) => !data.draft && data.section === 'nature'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({ title: entry.data.title, href: `/nature/${entry.data.routeSlug}/` }));
const items = entries.map(({ data }) => ({
  title: data.title,
  description: data.description,
  date: data.date,
  meta: [data.location, data.method].filter(Boolean).join(' · '),
  href: data.relatedWriting[0] ? `/writing/${data.relatedWriting[0]}/` : undefined,
}));
---

<BaseLayout title="自然" description="自然观察、行走、摄影与地方记忆。">
  <h1>自然</h1>
  <p class="page-intro">植物·动物·季节·行走与观察·地方记忆</p>
  <SectionMap label="自然" items={mapItems} />

  <section aria-labelledby="nature-recent-observations">
    <h2 id="nature-recent-observations">最近观察</h2>
    <DatedTextList items={items} />
  </section>
</BaseLayout>
