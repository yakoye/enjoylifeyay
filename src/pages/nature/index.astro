---
import { getCollection, getEntry } from 'astro:content';
import DatedTextList from '../../components/DatedTextList.astro';
import SectionMap from '../../components/SectionMap.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVisibleSectionPages } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'nature');
if (!page) throw new Error('Missing Markdown page content: nature');
const allEntries = await getCollection('nature');
type PublishedNature = (typeof allEntries)[number] & { data: Extract<(typeof allEntries)[number]['data'], { draft: false }> };
const entries = allEntries.filter((entry): entry is PublishedNature => entry.data.draft === false)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = await getVisibleSectionPages('nature');
const items = entries.map(({ data }) => ({
  title: data.title,
  description: data.description,
  date: data.date,
  meta: [data.location, data.method].filter(Boolean).join(' · '),
  href: data.relatedWriting[0] ? `/writing/${data.relatedWriting[0]}/` : undefined,
}));
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <SectionMap label={page.data.title} sectionHref="/nature/" items={mapItems} />

  <section aria-labelledby="nature-recent-observations">
    <h2 id="nature-recent-observations">最近观察</h2>
    <DatedTextList items={items} />
  </section>
</BaseLayout>
