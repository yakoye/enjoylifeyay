---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('sitePages', 'now');
const home = await getEntry('sitePages', 'home');
if (!page || !home) throw new Error('Missing Markdown page content: now or home');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <ul class="plain-list">{home.data.nowItems.map((item) => <li>{item}</li>)}</ul>
</BaseLayout>
