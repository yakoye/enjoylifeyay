---
import { getCollection } from 'astro:content';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const labels = {
  'technical-spec': '技术资料与规范',
  'website-knowledge': '网站与知识库',
  'software-tool': '软件与工具',
  article: '文章与长文',
  'design-media-font': '设计、图片与字体',
  'long-term-reference': '长期参考资料',
} as const;

const allEntries = await getCollection('favorites');
type PublishedEntry = (typeof allEntries)[number] & { data: Extract<(typeof allEntries)[number]['data'], { draft: false }> };
const entries = allEntries.filter((entry): entry is PublishedEntry => entry.data.draft === false);
const groups = Object.entries(labels).map(([category, title]) => ({
  title,
  items: entries
    .filter((entry) => entry.data.category === category)
    .map(({ data }) => ({ title: data.name, description: data.note, href: data.url })),
}));
---

<BaseLayout title="收藏" description="附有中文备注的长期参考资料。">
  <h1>收藏</h1>
  <p class="page-intro">只公开已整理且有说明的收藏，不展示裸链接。</p>
  <DirectoryList groups={groups} emptyMessage="暂无已整理并公开的收藏。" />
</BaseLayout>
