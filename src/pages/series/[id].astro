---
import { getCollection } from 'astro:content';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const [seriesEntries, writingEntries] = await Promise.all([
    getCollection('series', ({ data }) => !data.draft),
    getCollection('writing', ({ data }) => !data.draft),
  ]);
  return seriesEntries
    .filter((series) => writingEntries.some((entry) => entry.data.series.includes(series.data.id)))
    .map((entry) => ({ params: { id: entry.data.id } }));
}

const { id } = Astro.params;
const seriesEntries = await getCollection('series', ({ data }) => !data.draft);
const series = seriesEntries.find((entry) => entry.data.id === id);
if (!series) {
  return new Response(null, { status: 404 });
}

const writing = (await getCollection('writing', ({ data }) => !data.draft && data.series.includes(series.data.id)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const sectionHref = series.data.id.startsWith('life-')
  ? '/life/'
  : series.data.id === 'reading-learning' || series.data.id === 'knowledge-obsidian'
    ? '/reading/'
    : '/technology/';
---

<BaseLayout title={series.data.title} description={series.data.description} activeNav={sectionHref}>
  <h1>{series.data.title}</h1>
  <p class="page-intro">{series.data.description}</p>
  {series.data.audience && <p class="meta-muted">适合：{series.data.audience}</p>}
  <WritingList entries={writing} />
  <p class="aux-links"><a href={sectionHref}>返回对应栏目</a></p>
</BaseLayout>
