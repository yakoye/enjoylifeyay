---
import { getCollection } from 'astro:content';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = (await getCollection('series', ({ data }) => !data.draft)).sort((a, b) => a.data.order - b.data.order);
const writing = await getCollection('writing', ({ data }) => !data.draft);
const groupDefinitions: Array<{ title: string; ids: string[] }> = [
  { title: '技术与工程', ids: ['pcie-high-speed-interconnect', 'chip-firmware-soc', 'dev-environment-productivity', 'chrome-web-tools', 'cloudflare-personal-site'] },
  { title: '记录与观察', ids: ['knowledge-obsidian', 'reading-learning', 'nature-walking'] },
  { title: '生活与运动', ids: ['life-cycling', 'life-running'] },
];
const groups = groupDefinitions.map(({ title, ids }) => ({
  title,
  items: entries
    .filter((entry) => ids.includes(entry.data.id))
    .map(({ data }) => {
      const count = writing.filter((entry) => entry.data.series.includes(data.id)).length;
      return { title: data.title, description: data.description, meta: count > 0 ? `${count}篇` : undefined, href: `/series/${data.id}/` };
    }),
}));
---

<BaseLayout title="专题" description="按长期主题组织的文章、工具与项目目录。">
  <h1>专题</h1>
  <p class="page-intro">专题不是标签云，而是可持续维护的阅读路径。没有可靠数据时不显示完成度。</p>
  <DirectoryList groups={groups} />
</BaseLayout>
