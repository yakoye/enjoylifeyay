---
import { getCollection, getEntry } from 'astro:content';
import WritingList from '../components/WritingList.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const home = await getEntry('sitePages', 'home');
if (!home) throw new Error('Missing Markdown page content: home');

const writing = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 6);
const featuredSection = await getEntry('sectionPages', 'technology/technology-pcie');
const featuredTool = (await getCollection('tools', ({ data }) => !data.draft))
  .find((entry) => entry.data.featured && ['available', 'development'].includes(entry.data.status));
---

<BaseLayout title={home.data.title} description={home.data.description}>
  <div class="home-intro">
    <h1>{home.data.title}</h1>
    <p class="tagline">{home.data.tagline}</p>
  </div>

  <section aria-labelledby="recent-writing">
    <div class="section-heading"><h2 id="recent-writing">最近更新</h2><a href="/archive/">全部归档</a></div>
    <WritingList entries={writing} />
  </section>

  <section aria-labelledby="current-work">
    <div class="section-heading"><h2 id="current-work">正在做</h2><a href="/now/">查看全部</a></div>
    <ul class="plain-list">{home.data.nowItems.map((item) => <li>{item}</li>)}</ul>
  </section>

  {featuredSection && <section aria-labelledby="featured-section">
    <h2 id="featured-section">技术入口</h2>
    <p class="feature-line"><a href={`/technology/${featuredSection.data.routeSlug}/`}>{featuredSection.data.title}</a><span>{featuredSection.data.description}</span></p>
  </section>}

  {featuredTool && <section aria-labelledby="featured-tool">
    <h2 id="featured-tool">一个工具</h2>
    <p class="feature-line"><a href="/tools/">{featuredTool.data.name}</a><span>{featuredTool.data.description}</span></p>
  </section>}
</BaseLayout>
