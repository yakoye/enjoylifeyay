---
import { getCollection, getEntry } from 'astro:content';
import ArchiveTimeline from '../../components/ArchiveTimeline.astro';
import DirectoryList from '../../components/DirectoryList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { legacyArchiveEntries, legacySourceLinks } from '../../data/legacyArchive';

const page = await getEntry('sitePages', 'archive');
if (!page) throw new Error('Missing Markdown page content: archive');
const publishedWriting = await getCollection('writing', ({ data }) => !data.draft);
const localEntries = publishedWriting.map((entry) => ({
  id: `local-${entry.id}`,
  title: entry.data.title,
  href: `/writing/${entry.id}/`,
  date: entry.data.date.toISOString().slice(0, 10),
  source: '本站',
}));
const publishedSourceUrls = new Set(publishedWriting.map((entry) => entry.data.sourceUrl).filter(Boolean));
const externalEntries = legacyArchiveEntries.filter((entry) => !publishedSourceUrls.has(entry.href));

const archiveItems = [...localEntries, ...externalEntries]
  .sort((a, b) => b.date.localeCompare(a.date) || a.title.localeCompare(b.title, 'zh-CN'));

const sourceGroups = legacySourceLinks.length ? [{
  title: '其他历史来源',
  items: legacySourceLinks.map((item) => ({
    title: item.title,
    description: item.description,
    href: item.href,
  })),
}] : [];
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <ArchiveTimeline items={archiveItems} />
  {sourceGroups.length > 0 && <DirectoryList groups={sourceGroups} />}
</BaseLayout>
