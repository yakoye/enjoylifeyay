---
import { getCollection } from 'astro:content'; import WritingList from '../../components/WritingList.astro'; import BaseLayout from '../../layouts/BaseLayout.astro';
const entries = (await getCollection('writing', ({ data }) => !data.draft)).sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf());
const years = [...new Set(entries.map((entry) => entry.data.date.getFullYear()))];
---
<BaseLayout title="归档" description="按首次发布时间整理的写作归档。"><h1>归档</h1><p class="page-intro">迁入时间不改变旧文章所在年份。</p>{years.length ? years.map((year) => <section><h2>{year}</h2><WritingList entries={entries.filter((entry) => entry.data.date.getFullYear() === year)} /></section>) : <p class="empty-state">暂无已公开文章。</p>}</BaseLayout>
