---
import { getCollection } from 'astro:content';
import SectionMap from '../../components/SectionMap.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allLifeWriting = (await getCollection('writing', ({ data }) => !data.draft && data.domain === 'life'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = (await getCollection('sectionPages', ({ data }) => !data.draft && data.section === 'life'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({ title: entry.data.title, href: `/life/${entry.data.routeSlug}/` }));
---

<BaseLayout title="生活" description="思考、运动、饮食、旅行、家庭与日常方法的长期记录。">
  <h1>生活</h1>
  <p class="page-intro">思考、运动、饮食、旅行、家庭与日常方法的长期记录。</p>
  <SectionMap label="生活" items={mapItems} />

  <section aria-labelledby="life-recent-writing">
    <h2 id="life-recent-writing">最近生活记录</h2>
    <WritingList entries={allLifeWriting.slice(0, 8)} />
  </section>
</BaseLayout>
