---
import { getCollection, getEntry } from 'astro:content';
import SectionMap from '../../components/SectionMap.astro';
import WritingList from '../../components/WritingList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isInParentSection } from '../../config/content-model';
import { getVisibleSectionPages } from '../../lib/section-pages';

const page = await getEntry('sitePages', 'life');
if (!page) throw new Error('Missing Markdown page content: life');
const allLifeWriting = (await getCollection('writing', ({ data }) => !data.draft && isInParentSection(data.section, 'life')))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const mapItems = await getVisibleSectionPages('life');
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <SectionMap label={page.data.title} sectionHref="/life/" items={mapItems} />

  <section aria-labelledby="life-recent-writing">
    <h2 id="life-recent-writing">最近生活记录</h2>
    <WritingList entries={allLifeWriting.slice(0, 8)} />
  </section>
</BaseLayout>
