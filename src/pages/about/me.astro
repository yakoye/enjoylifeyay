---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('sitePages', 'about-me');
if (!page) throw new Error('Missing Markdown page content: about-me');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <article>
    <header class="article-header">
      <h1>{page.data.title}</h1>
      {page.data.eyebrow && <div class="writing-meta">{page.data.eyebrow}</div>}
    </header>
    <div class="article-prose page-prose"><Content /></div>
  </article>
</BaseLayout>
