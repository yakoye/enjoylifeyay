---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = await getEntry('sitePages', 'about');
if (!page) throw new Error('Missing Markdown page content: about');
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <h1>{page.data.title}</h1>
  <p class="page-intro">{page.data.intro}</p>
  <article class="article-prose page-prose"><Content /></article>
</BaseLayout>
