---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { categoryLabels, formatLabels } from '../config/site';
import { site } from '../config/site';
import CopyCode from '../components/CopyCode.astro';
import Comments from '../components/Comments.astro';

interface Heading { depth: number; slug: string; text: string; }
interface Props { entry: CollectionEntry<'writing'>; headings?: Heading[]; }
const { entry, headings = [] } = Astro.props;
const { data } = entry;
const isMeaningfulDate = (value?: Date | null): value is Date => Boolean(value && !Number.isNaN(value.valueOf()) && value.valueOf() !== 0);
const formatDate = (value?: Date | null) => isMeaningfulDate(value) ? value.toISOString().slice(0, 10) : '';
const updatedAt = isMeaningfulDate(data.updated) ? data.updated : undefined;
const sourceLabels = { native: '本站', CSDN: 'CSDN', Zhihu: '知乎', EnjoyLifeBlog: 'EnjoyLifeBlog' } as const;
const domainRoutes = { technology: '/technology/', reading: '/reading/', life: '/life/', nature: '/nature/', tool: '/tools/' } as const;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
const allSeries = await getCollection('series', ({ data }) => !data.draft);
const relatedSeries = data.series
  .map((id) => allSeries.find((seriesEntry) => seriesEntry.data.id === id))
  .filter((seriesEntry): seriesEntry is CollectionEntry<'series'> => Boolean(seriesEntry));
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting', headline: data.title,
  description: data.description, datePublished: data.date.toISOString(),
  dateModified: (updatedAt || data.date).toISOString(), mainEntityOfPage: `${site.url}/writing/${entry.id}/`,
};
---

<BaseLayout title={data.title} description={data.description} contentType="文章" publishedAt={data.date} activeNav={domainRoutes[data.domain]}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <header class="article-header">
      <h1>{data.title}</h1>
      <div class="writing-meta"><a href={domainRoutes[data.domain]}>{categoryLabels[data.domain]}</a> · {formatLabels[data.format]}{data.tags.length > 0 && ` · ${data.tags.join(' / ')}`}</div>
      {relatedSeries.length > 0 && (
        <div class="article-series">
          所属专题：
          {relatedSeries.map((seriesEntry, index) => (
            <>
              {index > 0 && ' · '}
              <a href={`/series/${seriesEntry.data.id}/`}>{seriesEntry.data.title}</a>
            </>
          ))}
        </div>
      )}
      <div class="article-meta">
        <span>{data.source === 'native' ? '发布' : '首次发布'}：{formatDate(data.date)}</span>
        {data.source !== 'native' && <span>来源：{sourceLabels[data.source]}</span>}
        {data.migratedAt && <span>迁入本站：{formatDate(data.migratedAt)}</span>}
        {updatedAt && <span>最后修订：{formatDate(updatedAt)}</span>}
        {data.sourceUrl && <a href={data.sourceUrl} target="_blank" rel="noopener noreferrer">原文</a>}
      </div>
    </header>
    {toc.length >= 1 && <details class="article-toc"><summary aria-label="展开或收起目录">目录</summary><ol>{toc.map((heading) => <li class:list={{ nested: heading.depth === 3, 'nested-deep': heading.depth === 4 }}><a href={`#${heading.slug}`}>{heading.text}</a></li>)}</ol></details>}
    <div class="article-prose"><slot /></div>
    <Comments article={entry.id} />
  </article>
  <CopyCode />
</BaseLayout>
