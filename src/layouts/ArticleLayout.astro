---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { categoryLabels, formatLabels } from '../config/site';
import { site } from '../config/site';
import CopyCode from '../components/CopyCode.astro';

interface Heading { depth: number; slug: string; text: string; }
interface Props { entry: CollectionEntry<'writing'>; headings?: Heading[]; }
const { entry, headings = [] } = Astro.props;
const { data } = entry;
const formatDate = (value?: Date | null) => value && new Intl.DateTimeFormat('zh-CN', { dateStyle: 'long' }).format(value);
const sourceLabels = { native: '本站', CSDN: 'CSDN', Zhihu: '知乎', EnjoyLifeBlog: 'EnjoyLifeBlog' } as const;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting', headline: data.title,
  description: data.description, datePublished: data.date.toISOString(),
  dateModified: (data.updated || data.date).toISOString(), mainEntityOfPage: `${site.url}/writing/${entry.id}/`,
};
---

<BaseLayout title={data.title} description={data.description} contentType="文章" publishedAt={data.date}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article>
    <header class="article-header">
      <h1>{data.title}</h1>
      <div class="writing-meta">{categoryLabels[data.domain]} · {formatLabels[data.format]}{data.tags.length > 0 && ` · ${data.tags.join(' / ')}`}</div>
      <div class="article-meta">
        <span>首次发布：{formatDate(data.date)}</span>
        <span>来源：{sourceLabels[data.source]}</span>
        {data.migratedAt && <span>迁入本站：{formatDate(data.migratedAt)}</span>}
        {data.updated && <span>最后修订：{formatDate(data.updated)}</span>}
        {data.sourceUrl && <a href={data.sourceUrl} target="_blank" rel="noopener noreferrer">查看原文</a>}
      </div>
    </header>
    {toc.length >= 2 && <details class="article-toc"><summary>文章目录</summary><ol>{toc.map((heading) => <li class:list={{ nested: heading.depth === 3 }}><a href={`#${heading.slug}`}>{heading.text}</a></li>)}</ol></details>}
    <div class="article-prose"><slot /></div>
  </article>
  <CopyCode />
</BaseLayout>
