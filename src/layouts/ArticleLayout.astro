---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { getSectionInfo } from '../config/content-model';
import { getPublicTagSet, tagHref } from '../lib/tags';
import { site } from '../config/site';
import CopyCode from '../components/CopyCode.astro';
import ArticleToc from '../components/ArticleToc.astro';

interface Heading { depth: number; slug: string; text: string; }
interface Props { entry: CollectionEntry<'writing'>; headings?: Heading[]; }
const { entry, headings = [] } = Astro.props;
const { data } = entry;
const isMeaningfulDate = (value?: Date | null): value is Date => Boolean(value && !Number.isNaN(value.valueOf()) && value.valueOf() !== 0);
const dateParts = (value?: Date | null) => {
  if (!isMeaningfulDate(value)) return null;
  const parts = new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Shanghai',
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', second: '2-digit', hourCycle: 'h23',
  }).formatToParts(value);
  const get = (type: Intl.DateTimeFormatPartTypes) => parts.find((part) => part.type === type)?.value ?? '';
  return { year: get('year'), month: get('month'), day: get('day'), hour: get('hour'), minute: get('minute'), second: get('second') };
};
const formatDate = (value?: Date | null) => {
  const parts = dateParts(value);
  return parts ? `${parts.year}-${parts.month}-${parts.day}` : '';
};
const formatDateTime = (value?: Date | null) => {
  const parts = dateParts(value);
  return parts ? `${parts.year}-${parts.month}-${parts.day} ${parts.hour}:${parts.minute}:${parts.second}` : '';
};
const publishedAt = data.publishedAt;
const updatedAt = isMeaningfulDate(data.updated) ? data.updated : undefined;
const section = getSectionInfo(data.section);
const publicTagSet = getPublicTagSet(await getCollection('writing', ({ data: item }) => !item.draft));
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting', headline: data.title,
  description: data.description, datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt || publishedAt).toISOString(), mainEntityOfPage: `${site.url}/writing/${entry.id}/`,
};
---

<BaseLayout title={data.title} description={data.description} contentType="文章" publishedAt={publishedAt} activeNav={section.parentHref}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article-page">
    <header class="article-header">
      <h1>{data.title}</h1>
      <div class="writing-meta">
        <a href={section.parentHref}>{section.parentLabel}</a>
        <span aria-hidden="true"> · </span>
        <a href={section.href}>{section.label}</a>
        {data.tags.length > 0 && <>
          <span aria-hidden="true"> · </span>
          {data.tags.map((tag, index) => <>
            {index > 0 && <span aria-hidden="true"> / </span>}
            {publicTagSet.has(tag) ? <a href={tagHref(tag)}>{tag}</a> : <span>{tag}</span>}
          </>)}
        </>}
      </div>
      <div class="article-meta">
        <span>发布：{formatDateTime(publishedAt)}</span>
        {updatedAt && <span>最后修订：{formatDate(updatedAt)}</span>}
      </div>
    </header>
    {toc.length >= 1 && <ArticleToc headings={toc} />}
    <div class="article-prose"><slot /></div>
  </article>
  <CopyCode />
</BaseLayout>
