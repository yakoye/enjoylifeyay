{
  "name": "enjoy-life",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "check:links": "node scripts/check-built-links.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run check && npm test && npm run build && npm run check:links",
    "deploy:pages": "npx wrangler pages deploy dist --project-name enjoylifeyay --branch main"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  }
}
