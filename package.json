{
  "name": "enjoy-life",
  "version": "0.25.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run sync:legacy-archive && npm run verify:public-content && npm run audit:public-copy && astro build && pagefind --site dist --force-language zh --silent && node scripts/prefix-base-path.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "check:links": "node scripts/check-built-links.mjs",
    "test": "node --test tests/*.test.mjs",
    "verify": "npm run check && npm test && npm run audit:toc && npm run audit:public-copy && npm run verify:science-references && npm run verify:public-content && npm run verify:legacy-assets && npm run build && npm run check:links",
    "deploy:pages": "npx wrangler pages deploy dist --project-name enjoylifeyay --branch main",
    "sync:legacy-archive": "node scripts/sync-legacy-archive.mjs",
    "import:legacy-images": "node scripts/import-legacy-images.mjs",
    "preview:pages": "npx wrangler pages dev dist",
    "audit:toc": "node scripts/audit-writing-toc.mjs",
    "audit:public-copy": "node scripts/audit-public-copy.mjs",
    "preview:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\local-preview.ps1",
    "preview:local:install": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\local-preview.ps1 -Install",
    "preview:local:stop": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\stop-local-preview.ps1",
    "fetch:legacy-assets": "node scripts/fetch-legacy-assets.mjs",
    "verify:legacy-assets": "node scripts/verify-legacy-assets.mjs",
    "verify:public-content": "node scripts/verify-public-content-private.mjs",
    "verify:science-references": "node scripts/verify-science-references.mjs",
    "clean:obsolete-content": "node scripts/clean-obsolete-content.mjs",
    "precheck": "npm run clean:obsolete-content",
    "prebuild": "npm run clean:obsolete-content"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "pagefind": "^1.5.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  }
}
